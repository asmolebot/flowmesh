{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/flowmesh/normalized-message.schema.json",
  "title": "NormalizedMessage",
  "description": "Common envelope shape for all provider messages in flowmesh",
  "type": "object",
  "required": [
    "id", "provider", "account", "subject", "receivedAt",
    "from", "to", "cc", "snippet", "labels", "attachments",
    "flags", "refs", "meta"
  ],
  "properties": {
    "id": { "type": "string" },
    "provider": { "type": "string" },
    "account": { "type": "string" },
    "mailbox": { "type": "string" },
    "threadId": { "type": "string" },
    "subject": { "type": "string" },
    "from": {
      "type": "array",
      "items": { "$ref": "#/$defs/address" }
    },
    "to": {
      "type": "array",
      "items": { "$ref": "#/$defs/address" }
    },
    "cc": {
      "type": "array",
      "items": { "$ref": "#/$defs/address" }
    },
    "receivedAt": {
      "type": "string",
      "format": "date-time"
    },
    "snippet": { "type": "string" },
    "bodyText": { "type": ["string", "null"] },
    "bodyHtml": { "type": ["string", "null"] },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "attachments": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachment" }
    },
    "flags": { "$ref": "#/$defs/flags" },
    "refs": { "$ref": "#/$defs/refs" },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "address": {
      "type": "object",
      "required": ["address"],
      "properties": {
        "name": { "type": ["string", "null"] },
        "address": { "type": "string" }
      },
      "additionalProperties": false
    },
    "attachment": {
      "type": "object",
      "required": ["filename", "mimeType"],
      "properties": {
        "filename": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "flags": {
      "type": "object",
      "required": ["read", "starred", "archived"],
      "properties": {
        "read": { "type": "boolean" },
        "starred": { "type": "boolean" },
        "archived": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "refs": {
      "type": "object",
      "required": ["providerId"],
      "properties": {
        "providerId": { "type": "string" },
        "providerThreadId": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
